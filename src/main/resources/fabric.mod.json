{
  "schemaVersion": 1,
  "id": "linear-build-suite",
  "version": "${version}",
  "name": "Linear Build Suite",
  "description": "Meteor Client addon for automated rail and tunnel construction.",
  "authors": [
    "KillerMelon"
  ],
  "contact": {
    "sources": "https://github.com/killermelon1458/linear-build-suite"
  },
  "icon": "assets/linearbuildsuite/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "dev.killermelon.linearbuildsuite.LinearBuildSuite"
    ]
  },
  "mixins": [
    "linear-build-suite.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": [
      "${mc_version}"
    ],
    "meteor-client": "*"
  }
}